# Database
DATABASE_URL=postgresql://user:password@db:5432/money_db

# Redis
REDIS_URL=redis://redis:6379/0

# JWT
JWT_SECRET_KEY=change_this_to_a_long_random_string
JWT_REFRESH_SECRET_KEY=change_this_to_another_long_random_string

# Encryption (for sensitive columns)
ENCRYPTION_KEY=base64_encoded_32_byte_key

# License Server (for validation)
LICENSE_SERVER_URL=https://your-license-server.com/validate

# External API Keys (stubs)
STRIPE_SECRET_KEY=sk_test_...
PAYPAL_CLIENT_ID=...
PAYPAL_SECRET=...
MPESA_CONSUMER_KEY=...
MPESA_CONSUMER_SECRET=...

# Exchange Rate API
EXCHANGE_RATE_API_KEY=your_api_key
EXCHANGE_RATE_API_URL=https://api.exchangerate.host/latest

# Admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD_HASH=bcrypt_hash_here
