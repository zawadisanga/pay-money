# Database (Heroku Postgres add-on)
DATABASE_URL=postgresql://user:password@localhost:5432/money_db

# Redis (Heroku Redis add-on)
REDIS_URL=redis://localhost:6379

# JWT Secrets
JWT_SECRET=your_super_secret_jwt_key_change_this
JWT_REFRESH_SECRET=your_super_secret_refresh_key_change_this

# Encryption Key (base64, 32 bytes)
ENCRYPTION_KEY=base64_encoded_32_byte_key_here

# Platform Settings
PLATFORM_USER_ID=platform_revenue_account
DEFAULT_FEE_PERCENT=2.5
MIN_FEE=0.01
MAX_FEE=10.00

# Exchange Rate API
EXCHANGE_RATE_API_KEY=your_api_key
EXCHANGE_RATE_API_URL=https://api.exchangerate.host/latest

# External Providers (M-Pesa, Stripe, PayPal)
MPESA_CONSUMER_KEY=your_mpesa_key
MPESA_CONSUMER_SECRET=your_mpesa_secret
STRIPE_SECRET_KEY=sk_test_xxx
PAYPAL_CLIENT_ID=xxx
PAYPAL_SECRET=xxx

# Admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD_HASH=bcrypt_hash_here

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Environment
NODE_ENV=production
PORT=3000


heroku config:set JWT_SECRET=your_super_secret_key_here -a money-system-node
heroku config:set JWT_REFRESH_SECRET=your_refresh_secret_here -a money-system-node
heroku config:set ENCRYPTION_KEY=$(python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())") -a money-system-node
heroku config:set DEFAULT_FEE_PERCENT=2.5 -a money-system-node
heroku config:set MIN_FEE=0.01 -a money-system-node
heroku config:set MAX_FEE=10.00 -a money-system-node
heroku config:set NODE_ENV=production -a money-system-node
